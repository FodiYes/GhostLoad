# Копируй этот файл в deployment.toml и заполняй
# cp deployment.toml.example deployment.toml

# ─── URL бэкенда ─────────────────────────────────────────────────────────────
# Полный URL до api.php на твоём хостинге (http или https)
api_url = "https://твой-хост.com/public/api.php"

# ─── Профиль деплоя ──────────────────────────────────────────────────────────
# Должен совпадать с ключом массива в backend/config/deployments.php
# Пример: если в deployments.php написано 'my_profile' => [...] — пиши my_profile
profile = "my_profile"

# ─── Таймаут запроса ─────────────────────────────────────────────────────────
# Секунды. 15 обычно хватает, на медленных хостах можно поднять до 30
request_timeout = 15

# ─── HMAC-секрет ─────────────────────────────────────────────────────────────
# Должен совпадать с SECRET_KEY в backend/config/.env
# Это не мастер-ключ шифрования — это отдельный секрет для подписи запросов
api_secret = "тот_же_ключ_что_в_.env_SECRET_KEY"
