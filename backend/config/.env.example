# Копируй этот файл в .env и заполняй
# cp .env.example .env

APP_ENV=production

# ─── HMAC-подпись запросов ────────────────────────────────────────────────────
# Произвольная строка, главное чтобы совпадала с api_secret в configs/deployment.toml
# Генерить можно так: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=СЮДА_СВОЙ_СЕКРЕТНЫЙ_КЛЮЧ

# ─── Мастер-ключ для шифрования payload-файлов ───────────────────────────────
# 256-bit hex (64 символа). Генерится один раз при первой настройке.
# Команда: python -c "import secrets; print(secrets.token_hex(32))"
# ВАЖНО: не менять после того как зашифровал файлы — всё перестанет расшифровываться
MASTER_KEY=СЮДА_64_HEX_СИМВОЛА

# ─── Лимиты ──────────────────────────────────────────────────────────────────
# Максимальное отклонение timestamp запроса от серверного времени (секунды)
MAX_TIME_DRIFT=300

# Лимит запросов: не более RATE_LIMIT_REQ запросов за RATE_LIMIT_SEC секунд с одного IP
RATE_LIMIT_REQ=20
RATE_LIMIT_SEC=60
